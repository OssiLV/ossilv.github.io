---
import { getCollection, getEntry, render, type CollectionEntry } from "astro:content";
import Layout from "../../../../layouts/Layout.astro";
import CourseSidebar from "../../../../components/Course/CourseSidebar.astro";
import CourseNav from "../../../../components/Course/CourseNav.astro";

export async function getStaticPaths() {
    const lessons = await getCollection("lessons");
    const paths = lessons.map((lesson) => {
        const courseId = lesson.data.course.id;
        const module = lesson.data.module;
        const lessonId = lesson.id.split("/").pop();
        console.log(`Generating path: /courses/${courseId}/${module}/${lessonId}`); // Debug
        return {
            params: {
                courseId,
                module,
                lessonId,
            },
            props: { lesson },
        };
    });
    console.log("Generated paths:", paths.map((p) => p.params)); // Debug
    return paths;
}

const { lesson } = Astro.props as { lesson: CollectionEntry<"lessons"> };
if (!lesson || !lesson.id) {
    return Astro.redirect("/404"); // Redirect to 404 if lesson is invalid
}
const { Content, headings } = await render(lesson);
const course = await getEntry("courses", lesson.data.course.id);
const authors = await getCollection("authors");
const lessons = await getCollection("lessons");

const currentCourseId = course?.id;
const relatedLessons = lessons.filter(
    (lesson) => lesson.data.course.id === currentCourseId
);

const modulesMap: { [key: string]: CollectionEntry<"lessons">[] } = {};
relatedLessons.forEach((lesson) => {
    const module = lesson.data.module;
    if (!modulesMap[module]) modulesMap[module] = [];
    modulesMap[module].push(lesson);
});

const author = authors.find((a) => a.id === course?.data.author.id)?.data;
---

<Layout>
    <div class="grid grid-cols-1 lg:grid-cols-[300px_1fr_250px] gap-4 px-4 py-6">
        <!-- CỘT TRÁI -->
        <CourseSidebar modulesMap={modulesMap} currentCourseId={currentCourseId? currentCourseId : ""} lessonId={lesson.id} />

        <!-- CỘT GIỮA -->
        <main class="lg:overflow-y-auto max-h-screen px-2">
            <article id="main-content">
                <CourseNav course={course} isMainCourse={false}/>

                <h1 class="text-3xl font-bold text-gray-800 mt-4">{lesson.data.title}</h1>

                <div class="mt-4 text-sm text-gray-500 space-y-1">
                    <p>Module: {lesson.data.module.replace("_", " ").toUpperCase()}</p>
                    <p>Ngày xuất bản: {lesson.data.pubDate.toLocaleDateString("vi-VN")}</p>
                    {lesson.data.updatedDate && (
                            <p>Ngày cập nhật: {lesson.data.updatedDate.toLocaleDateString("vi-VN")}</p>
                    )}
                </div>

                {author && (
                        <div class="mt-4 text-sm text-gray-700">
                            👨‍🏫 Tác giả:
                            <a
                                    class="text-blue-600 hover:underline"
                                    href={author.sourceURL ?? "#"}
                                    target="_blank"
                                    rel="noopener noreferrer"
                            >
                                {author.name}
                            </a>
                        </div>
                )}

                <div class="prose prose-blue max-w-none mt-8">
                    <Content />
                </div>
            </article>
        </main>

        <!-- CỘT PHẢI -->
        <aside class="hidden lg:block overflow-y-auto max-h-screen pl-4">
            <h2 class="text-lg font-semibold text-gray-700 mb-2">📑 Mục lục</h2>
            <ul class="text-sm text-gray-600 space-y-1">
                {headings.map((h) => (
                        <li class={`pl-${h.depth * 2}`}>
                            <a href={`#${h.slug}`} class="hover:text-blue-600 hover:underline">{h.text}</a>
                        </li>
                ))}
            </ul>
        </aside>
    </div>
</Layout>