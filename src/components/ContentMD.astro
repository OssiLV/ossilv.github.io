---
import type { AstroComponentFactory } from 'astro/runtime/server/index.js';

interface Props {
    title: string;
    desc?: string;
    pubDate: Date;
    updatedDate: Date,
    tags?: string[];
    author?: {
      name?: string,
      sourceURL?: string,
      isCurrentSite?: boolean
    },
    class? : string
    Content: AstroComponentFactory,
  }

const { title, desc, pubDate, updatedDate, tags, author, Content, class: customClass } = Astro.props;
---

<div class=" break-words px-6 md:px-2 max-w-3xl mx-auto mb-4">
    <h1 class="scroll-m-20 text-4xl font-extrabold tracking-tight lg:text-5xl mb-4">
      {title}
    </h1>
    <p class="leading-7">
      {desc}
    </p>
    <p class="text-sm text-slate-700/90">Published date: {pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
    <p class="text-sm text-slate-700/90">Updated date: {updatedDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
    <a href=`${author?.isCurrentSite ? Astro.url.origin + author.sourceURL: author?.sourceURL}` class="text-sm text-slate-700/90 underline font-semibold">{author?.name}</p>
</div>

<article class="prose break-words px-6 md:px-2 max-w-3xl mx-auto">
    <Content />
</article>

<div class="mt-8 break-words px-6 md:px-2 max-w-3xl mx-auto">
    <div class="">
        {tags?.map(tag => (
            <a href={`/blog?tag=${tag}`} class="bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded mr-1">
            {tag}
            </a>
        ))}
    </div>
</div>