---
interface Props {
    headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;

// Debug: Log headings to inspect depths
// console.log("Headings:", JSON.stringify(headings, null, 2));
---

<aside class="hidden lg:block overflow-y-auto max-h-screen pl-4">
    <h2 class="text-lg font-semibold text-gray-700 dark:text-gray-300 mb-2">📑 Mục lục</h2>
    {headings.length > 0 ? (
            <ul class="text-sm text-gray-600 dark:text-gray-400 space-y-1">
                {headings.map((h) => (
                        <li class={`pl-${h.depth * 2} ${h.depth == 2 && "underline" }`}>
                            <a href={`#${h.slug}`} class="hover:text-blue-600 dark:hover:text-blue-400 hover:underline">{h.text}</a>
                        </li>
                ))}
            </ul>
    ) : (
            <p class="text-sm text-gray-600 dark:text-gray-400">Không có mục lục</p>
    )}
</aside>