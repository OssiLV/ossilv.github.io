---
import type { CollectionEntry } from "astro:content";

type ModuleWithLessons = CollectionEntry<"modules"> & {
    lessons: CollectionEntry<"lessons">[];
};

interface Props {
    relatedModulesWithLessons: ModuleWithLessons[];
    currentCourse: string;
    lessonId?: string;
}

const { relatedModulesWithLessons, currentCourse, lessonId } = Astro.props;
---

<aside
        class="hidden lg:block overflow-y-auto max-h-screen pr-3"
        id="course-sidebar"
>
    <h2 class="text-lg font-semibold mb-6 text-gray-700 dark:text-gray-300">
        📚 Nội dung khóa học
    </h2>
    <div class="space-y-4">
        {relatedModulesWithLessons
            .sort((a, b) => a.data.order - b.data.order)
            .map((module) => (
                    <details class="rounded-lg bg-gray-100 dark:bg-gray-800" open>
                        <summary class="cursor-pointer font-medium px-4 py-2 text-gray-800 dark:text-gray-200">
                            {module.data.title.toUpperCase()}
                        </summary>
                        <ul class="mt-2 ml-4 pb-2 space-y-2 dark:border-gray-700 pl-4">
                            {module.lessons
                                .sort((a, b) => a.data.order - b.data.order)
                                .map((l) => (
                                        <li>
                                            <a
                                                    href={`/courses/${currentCourse}/${module.id.split("/").pop()}/${l.id.split("/").pop()}`}
                                                    class={`text-sm transition-colors hover:text-gray-600 dark:hover:text-blue-400 ${l.id === lessonId ? "text-gray-700 dark:text-blue-500 font-semibold" : "text-gray-500 dark:text-blue-400"}`}
                                            >
                                                {l.data.title}
                                            </a>
                                        </li>
                                ))}
                        </ul>
                    </details>
            ))}
    </div>
</aside>

<button
        class="lg:hidden fixed top-20 right-4 z-50 p-2 bg-gray-100/30 dark:bg-gray-800/30 border border-gray-300 dark:border-gray-600 rounded-md hover:bg-gray-200/40 dark:hover:bg-gray-700/40 transition-colors"
        id="toggle-sidebar"
        aria-label="Toggle course sidebar"
>
    <svg
            class="w-6 h-6 text-gray-600 dark:text-gray-300"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
    >
        <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"
        ></path>
    </svg>
</button>

<style>
    /* Ensure sidebar is visible when active on mobile */
    #course-sidebar.active {
        display: block !important;
    }
</style>

<script>
    document.getElementById("toggle-sidebar")?.addEventListener("click", () => {
        console.log("Toggle button clicked"); // Debug log
        const sidebar = document.getElementById("course-sidebar");
        if (sidebar) {
            console.log("Sidebar found, toggling active class"); // Debug log
            sidebar.classList.toggle("active");
            if (sidebar.classList.contains("active")) {
                sidebar.classList.add(
                    "block",
                    "fixed",
                    "top-0",
                    "left-0",
                    "w-full",
                    "max-w-[300px]",
                    "h-full",
                    "bg-white",
                    "dark:bg-gray-900",
                    "z-40",
                    "p-4",
                    "shadow-lg"
                );
            } else {
                sidebar.classList.remove(
                    "block",
                    "fixed",
                    "top-0",
                    "left-0",
                    "w-full",
                    "max-w-[300px]",
                    "h-full",
                    "bg-white",
                    "dark:bg-gray-900",
                    "z-40",
                    "p-4",
                    "shadow-lg"
                );
                sidebar.classList.add("hidden", "lg:block");
            }
        } else {
            console.log("Sidebar element not found"); // Debug log
        }
    });
</script>