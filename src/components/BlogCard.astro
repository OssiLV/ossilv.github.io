---
interface Props {
  id: string;
  title: string;
  desc?: string;
  pubDate: Date;
  updatedDate: Date,
  tags: string[];
  author?: {
    name?: string,
    sourceURL?: string,
    isCurrentSite?: boolean
  },
  class? : string
}


const { title, id, desc, pubDate, updatedDate, tags, author, class: customClass } = Astro.props;


---



<article 
  class={`grid grid-flow-row grid-rows-1 gap-4  bg-white shadow-lg rounded-xl p-5 transition-transform hover:scale-105 ${customClass}`}
  data-title={title.toLowerCase()}
>
  <a href={`/blog/${id}`} class="block mb-2">
    <h3 class="scroll-m-20 text-2xl font-semibold tracking-tight">{title}</h2>
    <div class="my-2">
      <p class="text-sm text-muted-foreground">{desc}</p>
    </div>
    <p class="text-sm text-slate-700/90">Published date: {pubDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
    <p class="text-sm text-slate-700/90">Updated date: {updatedDate.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
    <div class="mt-3 flex flex-wrap gap-2">
      {tags.slice(0,3).map(tag => (
        <span class="bg-blue-100 text-blue-800 text-xs font-semibold px-2.5 py-0.5 rounded">
          {tag}
        </span>
      ))}

      {tags.length > 3 ?"...":""}
    </div>
  </a>
  <code class="relative rounded bg-muted px-[0.3rem] py-[0.2rem] font-mono text-sm font-semibold">
    <a class="text-gray-500 text-sm" href=`${author?.isCurrentSite ? Astro.url.origin + author.sourceURL: author?.sourceURL}`>{author?.name}</p>
  </code>
</article>
