---
interface Props {
    tag: string;
    className?: string;
}
const { tag, className } = Astro.props;
---

<a
        href={`/blog/tags/${tag}`}
        class={`inline-block px-3 py-1.5 mr-3 mb-3 rounded-full border  
           text-sm font-medium hover:shadow-sm bg-purple-100 text-purple-800
            border-purple-300 hover:bg-purple-200 hover:text-purple-900
           transition-all duration-200 ease-in-out ${className}`}
>
    #{tag}
</a>
